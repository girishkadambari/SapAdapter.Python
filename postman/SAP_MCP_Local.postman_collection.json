{
	"info": {
		"_postman_id": "sap-mcp-collection",
		"name": "SAP MCP Production Test Suite",
		"description": "Comprehensive test suite for SAP MCP Server. Requires tests/postman_adapter.py to be running.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01 Session Management",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Verify the Test Adapter is alive."
					}
				},
				{
					"name": "List Sessions (MCP)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"if (jsonData.result && jsonData.result.content) {",
									"    var sessions = JSON.parse(jsonData.result.content[0].text);",
									"    if (sessions.length > 0) {",
									"        pm.environment.set(\"session_id\", sessions[0].sessionId);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"tools/list\",\n    \"params\": {}\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						}
					}
				}
			]
		},
		{
